{
  "name": "nexploy-cli",
  "version": "0.1.0",
  "description": "Recovery CLI for self-hosted Nexploy instances — acts directly on the server database using the recovery key generated at install time.",
  "license": "GPL-3.0",
  "type": "module",
  "bin": {
    "nexploy": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.6.20",
    "commander": "^12.1.0",
    "pg": "^8.13.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
